<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Saikara.App.Views.DisplayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Saikara.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Background placeholder: a static gradient (REQUIREMENTS §5 — static image /
         gradient first, looping video later). Telop and pitch bar sit on top.

         The telop deliberately uses a FIXED bright karaoke palette and does NOT follow
         Light/Dark theme: the display surface is a performance output, not a themed app
         page. Colors are inline literals on purpose (no ThemeResource). -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0.0" Color="#FF101830" />
                <GradientStop Offset="1.0" Color="#FF000000" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Lyric telop area (two-line, color-wipe). The current line is a single TextBlock
             whose Foreground is a horizontal gradient with two coincident stops: everything
             before the shared offset is the "sung" color, everything after is "unsung".
             Code-behind glides the shared offset to ViewModel.WipeFraction each frame. -->
        <StackPanel
            Grid.Row="0"
            Margin="48"
            VerticalAlignment="Center"
            Spacing="16">
            <TextBlock
                x:Name="CurrentLineTextBlock"
                AutomationProperties.AutomationId="DisplayCurrentLyric"
                FontSize="64"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.CurrentLineText, Mode=OneWay}"
                TextAlignment="Center"
                TextWrapping="Wrap">
                <TextBlock.Foreground>
                    <!-- Two coincident stops form the wipe boundary. SungStop/UnsungStop offsets are
                         set from code-behind; colors are swapped to a flat bright fill when the line
                         is the instrumental placeholder (no wipe). -->
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop x:Name="SungStop" Offset="0.0" Color="#FFFFD54A" />
                        <GradientStop x:Name="UnsungStop" Offset="0.0" Color="#FFFFFFFF" />
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Next line: dimmer, un-wiped, shown ahead of the current line. -->
            <TextBlock
                AutomationProperties.AutomationId="DisplayNextLyric"
                FontSize="44"
                FontWeight="SemiBold"
                Foreground="#B3FFFFFF"
                Text="{x:Bind ViewModel.NextLineText, Mode=OneWay}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Real-time pitch bar (P3): the sung pitch vs the active reference note on a shared
             vertical MIDI axis. A faint framed band is the axis; a gold horizontal segment marks
             the current reference note's pitch; a cyan marker tracks the sung pitch. Both are
             positioned imperatively from code-behind (Canvas.SetTop on normalised VM values) since
             pixel layout depends on the live canvas height. Fixed bright colors on the dark surface
             — deliberately NOT themed (this is a performance output, like the telop). -->
        <Border
            Grid.Row="1"
            Height="160"
            Margin="48,0"
            AutomationProperties.AutomationId="DisplayPitchBar"
            AutomationProperties.Name="Pitch bar"
            Background="#33000000"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            CornerRadius="4">
            <Canvas
                x:Name="PitchCanvas"
                AutomationProperties.AutomationId="DisplayPitchCanvas"
                SizeChanged="OnPitchCanvasSizeChanged">

                <!-- Reference (target) note segment. Width is set in code-behind to a central band. -->
                <Rectangle
                    x:Name="ReferenceLine"
                    Height="6"
                    AutomationProperties.AutomationId="DisplayReferenceLine"
                    Fill="#FFFFD54A"
                    RadiusX="3"
                    RadiusY="3"
                    Visibility="Collapsed" />

                <!-- Sung-pitch marker. Moves vertically to the detected note; hidden when unvoiced. -->
                <Ellipse
                    x:Name="SungMarker"
                    Width="22"
                    Height="22"
                    AutomationProperties.AutomationId="DisplaySungMarker"
                    Fill="#FF35E0FF"
                    Visibility="Collapsed" />
            </Canvas>
        </Border>

        <!-- Status strip -->
        <TextBlock
            Grid.Row="2"
            Margin="48,16,48,24"
            FontSize="12"
            Foreground="#80FFFFFF"
            Text="Display output — secondary monitor"
            TextAlignment="Center" />

        <!-- Scoring result overlay (P4). Spans the whole surface and dims the telop/pitch bar
             behind it. Shown at song end via ViewModel.IsResultVisible; the Close button hides it.
             Fixed bright karaoke palette on a dark scrim — deliberately NOT themed, like the rest
             of the display surface (no ThemeResource). Inline color literals are intentional. -->
        <Grid
            Grid.RowSpan="3"
            Background="#CC000820"
            Visibility="{x:Bind local:DisplayWindow.BoolToVisibility(ViewModel.IsResultVisible), Mode=OneWay}">
            <Border
                MaxWidth="720"
                Margin="48"
                Padding="48,40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#F2101830"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                CornerRadius="16">
                <StackPanel Spacing="24">
                    <!-- Header: overall score (large) + grade (prominent) -->
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="#B3FFFFFF"
                        Text="採点結果 — Result"
                        TextAlignment="Center" />

                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="32">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                AutomationProperties.AutomationId="DisplayResultOverall"
                                FontSize="96"
                                FontWeight="SemiBold"
                                Foreground="#FFFFD54A"
                                Text="{x:Bind ViewModel.OverallScore, Mode=OneWay}"
                                TextAlignment="Center" />
                            <TextBlock
                                FontSize="14"
                                Foreground="#80FFFFFF"
                                Text="点 / 100"
                                TextAlignment="Center" />
                        </StackPanel>

                        <Border
                            Width="120"
                            Height="120"
                            VerticalAlignment="Center"
                            Background="#1AFFFFFF"
                            CornerRadius="60">
                            <TextBlock
                                AutomationProperties.AutomationId="DisplayResultGrade"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="72"
                                FontWeight="SemiBold"
                                Foreground="#FF35E0FF"
                                Text="{x:Bind ViewModel.Grade, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <!-- Sub-score breakdown: labelled ProgressBars -->
                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FFFFFFFF"
                            Text="音程 Pitch" />
                        <ProgressBar
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="DisplayResultPitchBar"
                            Maximum="100"
                            Minimum="0"
                            Value="{x:Bind ViewModel.PitchAccuracyValue, Mode=OneWay}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FFFFFFFF"
                            Text="{x:Bind ViewModel.PitchAccuracyText, Mode=OneWay}"
                            TextAlignment="Right" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FFFFFFFF"
                            Text="安定性 Stability" />
                        <ProgressBar
                            Grid.Row="1"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="DisplayResultStabilityBar"
                            Maximum="100"
                            Minimum="0"
                            Value="{x:Bind ViewModel.StabilityValue, Mode=OneWay}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FFFFFFFF"
                            Text="{x:Bind ViewModel.StabilityText, Mode=OneWay}"
                            TextAlignment="Right" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FFFFFFFF"
                            Text="抑揚 Expression" />
                        <ProgressBar
                            Grid.Row="2"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="DisplayResultExpressionBar"
                            Maximum="100"
                            Minimum="0"
                            Value="{x:Bind ViewModel.ExpressionValue, Mode=OneWay}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FFFFFFFF"
                            Text="{x:Bind ViewModel.ExpressionText, Mode=OneWay}"
                            TextAlignment="Right" />

                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FFFFFFFF"
                            Text="ロングトーン Long tone" />
                        <ProgressBar
                            Grid.Row="3"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="DisplayResultLongToneBar"
                            Maximum="100"
                            Minimum="0"
                            Value="{x:Bind ViewModel.LongToneValue, Mode=OneWay}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FFFFFFFF"
                            Text="{x:Bind ViewModel.LongToneText, Mode=OneWay}"
                            TextAlignment="Right" />
                    </Grid>

                    <!-- Technique counts -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="32">
                        <StackPanel>
                            <TextBlock
                                AutomationProperties.AutomationId="DisplayResultVibrato"
                                FontSize="28"
                                FontWeight="SemiBold"
                                Foreground="#FF35E0FF"
                                Text="{x:Bind ViewModel.VibratoCountText, Mode=OneWay}"
                                TextAlignment="Center" />
                            <TextBlock
                                FontSize="13"
                                Foreground="#B3FFFFFF"
                                Text="ビブラート"
                                TextAlignment="Center" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock
                                AutomationProperties.AutomationId="DisplayResultShakuri"
                                FontSize="28"
                                FontWeight="SemiBold"
                                Foreground="#FF35E0FF"
                                Text="{x:Bind ViewModel.ShakuriCountText, Mode=OneWay}"
                                TextAlignment="Center" />
                            <TextBlock
                                FontSize="13"
                                Foreground="#B3FFFFFF"
                                Text="しゃくり"
                                TextAlignment="Center" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock
                                AutomationProperties.AutomationId="DisplayResultKobushi"
                                FontSize="28"
                                FontWeight="SemiBold"
                                Foreground="#FF35E0FF"
                                Text="{x:Bind ViewModel.KobushiCountText, Mode=OneWay}"
                                TextAlignment="Center" />
                            <TextBlock
                                FontSize="13"
                                Foreground="#B3FFFFFF"
                                Text="こぶし"
                                TextAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <Button
                        Margin="0,8,0,0"
                        Padding="40,10"
                        HorizontalAlignment="Center"
                        AutomationProperties.AutomationId="DisplayResultClose"
                        AutomationProperties.Name="Close result"
                        Command="{x:Bind ViewModel.CloseResultCommand}"
                        Content="閉じる Close" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
