<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Saikara.App.Views.OperatorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Saikara.App.Views"
    xmlns:core="using:Saikara.Core.Library"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel
            Grid.Row="0"
            Padding="24,16"
            Spacing="2">
            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                Text="{x:Bind ViewModel.AppName}" />
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Operator console" />
        </StackPanel>

        <!-- Sidebar (song-select + key/tempo) | reservation queue -->
        <Grid Grid.Row="1" Padding="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: song-select remote + key/tempo + transport. Wrapped in a ScrollViewer
                 so the transport (incl. the seek slider) stays reachable on short windows. -->
            <ScrollViewer
                Grid.Column="0"
                Margin="0,0,24,0"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Auto">
                <StackPanel Spacing="16">

                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Song select" />

                <AutoSuggestBox
                    AutomationProperties.AutomationId="OperatorSearchBox"
                    PlaceholderText="Number, title or artist"
                    QueryIcon="Find"
                    QuerySubmitted="OnSearchQuerySubmitted"
                    Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextChanged="OnSearchTextChanged" />

                <ListView
                    Height="280"
                    AutomationProperties.AutomationId="OperatorSearchResultsList"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    DoubleTapped="OnSearchResultDoubleTapped"
                    ItemsSource="{x:Bind ViewModel.SearchResults}"
                    SelectedItem="{x:Bind ViewModel.SelectedSong, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:Song">
                            <StackPanel Padding="0,4" Spacing="2">
                                <TextBlock
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind Title}" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind Artist}" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{x:Bind Number}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button
                    AutomationProperties.AutomationId="OperatorAddToQueueButton"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.AddToQueueCommand}"
                    Content="Add to queue"
                    Style="{StaticResource AccentButtonStyle}" />

                <TextBlock
                    Margin="0,8,0,0"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Key &amp; tempo" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="{x:Bind local:OperatorWindow.FormatKey(ViewModel.KeyOffset), Mode=OneWay}" />
                    <Button
                        Grid.Column="1"
                        AutomationProperties.AutomationId="OperatorKeyDownButton"
                        AutomationProperties.Name="Key down"
                        Command="{x:Bind ViewModel.KeyDownCommand}"
                        Content="&#x2212;" />
                    <Button
                        Grid.Column="2"
                        AutomationProperties.AutomationId="OperatorKeyUpButton"
                        AutomationProperties.Name="Key up"
                        Command="{x:Bind ViewModel.KeyUpCommand}"
                        Content="&#x2B;" />
                </Grid>

                <NumberBox
                    AutomationProperties.AutomationId="OperatorTempoNumberBox"
                    Header="Tempo (%)"
                    Maximum="200"
                    Minimum="50"
                    SpinButtonPlacementMode="Inline"
                    Value="{x:Bind ViewModel.TempoPercent, Mode=TwoWay}" />

                <!-- Playback transport (P1) -->
                <TextBlock
                    Margin="0,8,0,0"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Playback" />

                <Button
                    AutomationProperties.AutomationId="OperatorOpenFileButton"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.OpenFileCommand}"
                    Content="Open MIDI file…" />

                <TextBlock
                    AutomationProperties.AutomationId="OperatorLoadedFileText"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.LoadedFileName, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />

                <InfoBar
                    AutomationProperties.AutomationId="OperatorPlaybackUnavailableInfoBar"
                    IsClosable="False"
                    IsOpen="{x:Bind local:OperatorWindow.Not(ViewModel.IsPlaybackEnabled), Mode=OneWay}"
                    Message="Playback is unavailable — the SoundFont could not be loaded."
                    Severity="Warning" />

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        AutomationProperties.AutomationId="OperatorPlayButton"
                        AutomationProperties.Name="Play"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.PlayCommand}"
                        IsEnabled="{x:Bind local:OperatorWindow.CanPlay(ViewModel.IsSongLoaded, ViewModel.IsPlaybackEnabled, ViewModel.PlaybackState), Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE768;" />
                    </Button>
                    <Button
                        Grid.Column="1"
                        AutomationProperties.AutomationId="OperatorPauseButton"
                        AutomationProperties.Name="Pause"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.PauseCommand}"
                        IsEnabled="{x:Bind local:OperatorWindow.CanPause(ViewModel.PlaybackState), Mode=OneWay}">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE769;" />
                    </Button>
                    <Button
                        Grid.Column="2"
                        AutomationProperties.AutomationId="OperatorStopButton"
                        AutomationProperties.Name="Stop"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.StopCommand}"
                        IsEnabled="{x:Bind local:OperatorWindow.CanStop(ViewModel.IsSongLoaded, ViewModel.PlaybackState), Mode=OneWay}">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71A;" />
                    </Button>
                </Grid>

                <Slider
                    AutomationProperties.AutomationId="OperatorSeekSlider"
                    AutomationProperties.Name="Seek"
                    IsEnabled="{x:Bind ViewModel.IsSongLoaded, Mode=OneWay}"
                    Maximum="{x:Bind ViewModel.DurationSeconds, Mode=OneWay}"
                    Minimum="0"
                    StepFrequency="1"
                    Value="{x:Bind ViewModel.PositionSeconds, Mode=TwoWay}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        AutomationProperties.AutomationId="OperatorElapsedText"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.ElapsedText, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="1"
                        AutomationProperties.AutomationId="OperatorTotalText"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.TotalText, Mode=OneWay}" />
                </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Right: reservation queue -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,12"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Reservation queue" />

                <ListView
                    Grid.Row="1"
                    AutomationProperties.AutomationId="OperatorReservationList"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    ItemsSource="{x:Bind ViewModel.ReservationQueue}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:Song">
                            <Grid Padding="0,4" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind Title}" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Artist}" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{x:Bind Number}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Window>
